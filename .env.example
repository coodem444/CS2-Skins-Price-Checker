# Copia este fichero a ".env" (mismo directorio que actualizar.py) y
# rellena tus valores reales. El ".env" NUNCA debe compartirse ni subirse
# a ningún repositorio — añádelo a .gitignore si usas control de versiones.

# ── Notion (obligatorio) ──────────────────────────────────────────────
# Token de tu integración interna: notion.so/my-integrations
NOTION_TOKEN=

# ID de la base de datos (32 caracteres, sin guiones, de la URL de Notion)
NOTION_DATABASE_ID=

# ── CSFloat (opcional — si se omite, esa fuente de precio se salta) ───
# Se obtiene en csfloat.com → perfil → pestaña "developer"
CSFLOAT_API_KEY=

# ── Discord (opcional — si se omite, no se envían alertas) ────────────
DISCORD_WEBHOOK=
